animations {
    // Uncomment to turn off all animations.
    // You can also put "off" into each individual animation to disable it.
    // off

    // Slow down all animations by this factor. Values below 1 speed them up instead.
    // slowdown 3.0

    // Individual animations.

    window-open {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
        precision mediump float;

        uniform float u_time;
        uniform float u_progress; // 0.0 (closed) to 1.0 (open)
        uniform vec2 u_resolution;
        uniform sampler2D u_texture;

        void main() {
            vec2 uv = gl_FragCoord.xy / u_resolution.xy;

            // Create an easing curve for the snap effect
            // As u_progress approaches 1.0, the distortion fades out (snaps into place)
            float snap = pow(1.0 - u_progress, 2.0);

            // Calculate a distortion wave
            // The wave frequency increases as the window reaches its destination
            float wave = sin(uv.y * 10.0 + u_time * 5.0) * 0.05 * snap;

            // Apply the distortion to the texture coordinates
            vec2 distortedUV = uv + vec2(wave, 0.0);

            // Sample the window texture
            vec4 color = texture2D(u_texture, distortedUV);

            // Combine distortion with a fade
            gl_FragColor = vec4(color.rgb, color.a * u_progress);
        }
        "
    }

    window-close {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
        precision mediump float;

        uniform float u_time;
        uniform float u_progress; // 1.0 (fully open) to 0.0 (fully closed)
        uniform vec2 u_resolution;

        // [Include the noise and fbm functions from the previous response here]

        void main() {
            vec2 uv = gl_FragCoord.xy / u_resolution.xy;

            // Dissipation logic:
            // As u_progress decreases, the smoke becomes more transparent
            // and drifts outward/upward.
            float drift = (1.0 - u_progress) * 2.0;
            vec2 q = vec2(fbm(uv + u_time * 0.2), fbm(uv + u_time * 0.1 + drift));

            float f = fbm(uv + q * 4.0);

            // Alpha multiplier based on closing progress
            // We multiply by u_progress so the window fades out as it closes
            float alpha = f * u_progress;

            // Optionally scale the smoke pattern to make it look like it's expanding/vanishing
            vec3 col = vec3(0.8, 0.8, 0.8) * f;

            gl_FragColor = vec4(col, alpha);
        }
        "
    }

}
